# Copy this file to .env for local development and change values as needed.
# Keep real passwords, API keys, and machine-specific paths out of git.

MYSQL_DATABASE=no_home
MYSQL_USER=no_home
MYSQL_PASSWORD=no_home_dev_password
MYSQL_ROOT_PASSWORD=root_dev_password
MYSQL_PORT=3306

DB_URL=jdbc:mysql://localhost:3306/no_home?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=no_home
DB_PASSWORD=no_home_dev_password

# Public data API key for backend apartment trade imports.
# Spring Boot reads this through public-data.service-key.
PUBLIC_DATA_SERVICE_KEY=

# Backend-side Kakao key, if a backend integration needs it.
KAKAO_MAP_API_KEY=

# Use a random secret of at least 32 bytes outside local development.
JWT_SECRET=change-me-local-jwt-secret-at-least-32-bytes
JWT_ACCESS_TOKEN_SECONDS=900
JWT_REFRESH_TOKEN_SECONDS=604800
JWT_COOKIE_SECURE=false

# SSAFY GMS API key for the Spring AI chatbot (OpenAI proxy).
# Spring Boot reads this through spring.ai.openai.api-key.
SSAFY_GMS_API_KEY=
# Optional overrides (defaults target the SSAFY GMS proxy / gpt-4o-mini).
# SSAFY_GMS_OPENAI_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1/
# AI_CHAT_MODEL=gpt-4o-mini

# AI chatbot request policy (optional overrides).
# 글자수 상한을 풀려면 별도 토글 없이 이 값을 크게 설정한다(예: 100000). 빈 입력 검증(400)은 항상 적용.
AI_CHAT_MAX_MESSAGE_LENGTH=500
# 내부 테스트용. false면 분당 한도(429)·동시요청(409)을 끈다. 운영에서는 반드시 true 유지.
AI_CHAT_RATE_LIMIT_ENABLED=true
AI_CHAT_RATE_LIMIT_REQUESTS=10
AI_CHAT_RATE_LIMIT_WINDOW=1m
AI_CHAT_CONNECT_TIMEOUT=3s
AI_CHAT_READ_TIMEOUT=25s
AI_CHAT_RETRY_MAX_ATTEMPTS=2

# AI diagnostics (safe metadata only). Keep these production defaults.
# For temporary local diagnostics, set enabled=true and both levels=DEBUG.
AI_CHAT_DIAGNOSTIC_LOGGING_ENABLED=false
AI_CHAT_LOG_LEVEL=INFO
AI_CHAT_DIAGNOSTIC_LOG_LEVEL=OFF
